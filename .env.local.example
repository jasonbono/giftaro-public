TURSO_DATABASE_URL=libsql://your-database-url.turso.io
TURSO_AUTH_TOKEN=your-auth-token
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Live webhook secret for "Your account" destination (payments, checkouts, charges).
STRIPE_WEBHOOK_SECRET=whsec_...
# Live webhook secret for "Connected accounts" destination (account.updated).
STRIPE_WEBHOOK_SECRET_CONNECT=whsec_...
# Optional: used for users with users.test_mode = 1 so you can keep running
# fake transactions alongside real ones. Same two-destination split.
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...
STRIPE_WEBHOOK_SECRET_TEST_CONNECT=whsec_...
RESEND_API_KEY=re_...
OPENAI_API_KEY=sk-...
INDEXNOW_KEY=your-indexnow-key
